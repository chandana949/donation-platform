generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String

  phone  String?
  age    Int?
  gender String?

  bloodGroup String?

  city  String?
  state String?

  role String?

  availableToDonate Boolean @default(true)

  isVerified Boolean @default(false)

  documentUrl        String?
  verificationStatus String  @default("PENDING")
  verifiedBloodGroup String?

  requests DonationRequest[]

  createdAt DateTime @default(now())
}

model DonationRequest {
  id String @id @default(cuid())

  bloodGroup String
  city       String
  urgency    String

  unitsNeeded Int

  hospital String?
  message  String?

  status String @default("OPEN")

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  acceptedById String?
}
